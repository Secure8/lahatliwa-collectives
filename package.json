{
  "name": "lahat-liwa-collectives",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:credits": "node --test src/lib/projectCredits.test.js",
    "test:media": "node --test src/lib/projectMediaCleanup.test.js",
    "test:team-roles": "node --test src/lib/teamRoles.test.js",
    "test:reconciliation": "node --test src/lib/storageReconciliation.test.js",
    "worker:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-storage-cleanup-worker.ps1",
    "worker:test": "powershell -ExecutionPolicy Bypass -File scripts/test-storage-cleanup-worker.ps1",
    "worker:rotate-secret": "powershell -ExecutionPolicy Bypass -File scripts/setup-storage-cleanup-worker.ps1 -RotateSecret",
    "worker:status": "powershell -ExecutionPolicy Bypass -File scripts/get-storage-cleanup-worker-status.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.5",
    "@tailwindcss/vite": "^4.1.11",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  }
}
