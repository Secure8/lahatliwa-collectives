VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GOOGLE_DRIVE_CONNECTOR_ENABLED=false
VITE_GOOGLE_DRIVE_TEST_UPLOAD_ENABLED=false
VITE_GOOGLE_DRIVE_PROJECT_GALLERY_ENABLED=false
VITE_R2_MEDIA_ENABLED=false

# Set the following only as Supabase Edge Function secrets, never as VITE_* values.
# GOOGLE_DRIVE_OAUTH_ENABLED=false
# GOOGLE_DRIVE_UPLOAD_ENABLED=false
# GOOGLE_DRIVE_CLIENT_ID=your_google_oauth_web_client_id
# GOOGLE_DRIVE_CLIENT_SECRET=store_with_supabase_secrets
# GOOGLE_DRIVE_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/google-drive-oauth-callback
# PUBLIC_SITE_URL=http://localhost:5173
# R2_MEDIA_ENABLED=false
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=store_with_supabase_secrets
# R2_SECRET_ACCESS_KEY=store_with_supabase_secrets
# R2_BUCKET_NAME=lahat-liwa-public-media
# R2_PUBLIC_BASE_URL=https://media.lahatliwa.studio
